# OpenPath environment configuration.
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Platform database. Use the pooled connection string for runtime and
# the direct connection string for Prisma migrations.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Auth.js
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Tenant Firebase credential encryption.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
OPENPATH_ENC_KEY="replace-me-with-a-base64-32-byte-key"

# Optional branding uploads.
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="branding"

# Optional email notifications.
RESEND_API_KEY=""
EMAIL_FROM="OpenPath <notifications@openpath.local>"
OPENPATH_EMAIL_NOTIFICATIONS="off"

# Optional opportunities integration.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/"
MONGODB_DB="extracurriculars"
MONGODB_COLLECTION="programs"

// OpenPath control-plane schema (Supabase Postgres).
// Tenant course/assignment/file/grade DATA lives in each tenant's own Firebase;
// this database only holds platform accounts, tenant config, ENCRYPTED Firebase
// credentials, memberships, invites/join codes, and an audit trail.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlatformRole {
  USER
  STUIMPACT_ADMIN
}

enum MembershipRole {
  OWNER
  TEACHER
  TA
  STUDENT
}

enum MemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum CredentialStatus {
  PENDING
  ACTIVE
  ERROR
}

enum OpportunityType {
  INTERNSHIP
  MENTORSHIP
  HACKATHON
  VOLUNTEER
  PROGRAM
  SCHOLARSHIP
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null for OAuth-only accounts
  platformRole  PlatformRole @default(USER)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  accounts       Account[]
  sessions       Session[]
  memberships    Membership[]
  createdTenants Tenant[]     @relation("TenantCreator")
  auditLogs      AuditLog[]
  guardianLinks  GuardianContact[] @relation("GuardianStudent")
}

// ---- Auth.js adapter models -------------------------------------------------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Tenancy ----------------------------------------------------------------
model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  logoUrl     String?
  theme       Json? // { primary, accent, headline, ... } — see lib/theme.ts
  plan        String   @default("free")
  createdById String
  createdBy   User     @relation("TenantCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships Membership[]
  firebase    FirebaseCredential?
  invitations Invitation[]
  joinCodes   JoinCode[]
  auditLogs   AuditLog[]
  aiConfig    TenantAIConfig?
  guardians   GuardianContact[]
}

// A tenant's connected Firebase project. The service-account JSON is stored ONLY
// as AES-256-GCM envelope ciphertext (see lib/crypto.ts) — never in plaintext.
model FirebaseCredential {
  id             String           @id @default(cuid())
  tenantId       String           @unique
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId      String
  storageBucket  String?
  clientConfig   Json? // public web config (apiKey/authDomain/...) — low sensitivity
  ciphertext     String           @db.Text
  iv             String
  authTag        String
  wrappedKey     String           @db.Text
  status         CredentialStatus @default(PENDING)
  lastVerifiedAt DateTime?
  lastError      String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

// A tenant's own AI provider key (e.g. Anthropic), stored ONLY as AES-256-GCM
// envelope ciphertext (see lib/crypto.ts). Decrypted server-side on demand.
model TenantAIConfig {
  id         String   @id @default(cuid())
  tenantId   String   @unique
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider   String   @default("anthropic")
  model      String   @default("claude-3-5-haiku-latest")
  enabled    Boolean  @default(true)
  ciphertext String   @db.Text
  iv         String
  authTag    String
  wrappedKey String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  tenantId  String
  role      MembershipRole @default(STUDENT)
  status    MemberStatus   @default(ACTIVE)
  title     String? // e.g. "Math Department", optional display title
  createdAt DateTime       @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model Invitation {
  id         String         @id @default(cuid())
  tenantId   String
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email      String
  role       MembershipRole @default(STUDENT)
  token      String         @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([tenantId])
  @@index([email])
}

model JoinCode {
  id        String         @id @default(cuid())
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String         @unique
  courseId  String? // course in the tenant's Firebase this code enrolls into
  role      MembershipRole @default(STUDENT)
  expiresAt DateTime?
  maxUses   Int?
  uses      Int            @default(0)
  createdAt DateTime       @default(now())

  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model GuardianContact {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentUserId String
  student       User     @relation("GuardianStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  name          String
  email         String
  relationship  String?
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([studentUserId])
}

model Opportunity {
  id            String          @id
  title         String
  org           String
  type          OpportunityType
  category      String
  description   String          @db.Text
  url           String
  location      String?
  cost          String?
  salary        String?
  mode          String?
  deadline      DateTime?
  featured      Boolean         @default(false)
  active        Boolean         @default(true)
  source        String?
  sourceUrl     String?
  sourceId      String?
  sourcePayload Json?
  sources       Json?
  canonicalKey  String?         @unique
  skills        String[]        @default([])
  gradeLevels   String[]        @default([])
  eligibility   String[]        @default([])
  tags          String[]        @default([])
  audiences     String[]        @default([])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([type])
  @@index([featured, active])
  @@index([category])
  @@index([org])
  @@index([source])
}

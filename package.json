{
  "name": "openpath-lms",
  "version": "0.1.0",
  "private": true,
  "description": "OpenPath is a multi-tenant learning management platform migrated from a Flask app to a modern Next.js, Prisma, and Firebase architecture.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:check": "node --env-file=.env scripts/check-db.mjs",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "firebase-admin": "^13.0.2",
    "lucide-react": "^0.469.0",
    "mongodb": "^7.3.0",
    "next": "^15.1.4",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.4",
    "prisma": "^6.2.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
